{
  "name": "grammar-correction-open-ai",
  "displayName": "Env Manager & Validator",
  "description": "Smart Environment Variable manager for your workspace",
  "publisher": "LokeshChoudhary",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lokeshchoudharyprogrammer/Grammar-Correction-VSCode-Extension"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:**/.env*",
    "workspaceContains:**/*.env"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "env-manager.syncEnv",
        "title": "Env Manager: Sync .env with .env.example"
      },
      {
        "command": "env-manager.switchEnv",
        "title": "Env Manager: Switch Environment Profile"
      },
      {
        "command": "env-manager.findDeadVariables",
        "title": "Env Manager: Find Unused/Dead Variables"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
